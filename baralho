<script>
const SEU_NUMERO = '5527992832260'; // ← troque pelo seu número com DDD
let carrinho = [];

function adicionarCarta(btn) {
  const cartaEl = btn.closest('.carta-item');
  const temaEl = btn.closest('.tema');
  const tema = temaEl ? temaEl.getAttribute('data-tema') : 'Baralho';
  const subtipo = btn.getAttribute('data-subtipo');
  const id = tema + '|' + subtipo;

  if (btn.classList.contains('adicionado')) {
    carrinho = carrinho.filter(c => c.id !== id);
    btn.classList.remove('adicionado');
    btn.textContent = 'Quero esta carta';
  } else {
    carrinho.push({ id, tema, subtipo });
    btn.classList.add('adicionado');
    btn.textContent = subtipo;
  }

  atualizarCarrinho();
}

function atualizarCarrinho() {
  const bar = document.getElementById('carrinhoBar');
  const num = document.getElementById('carrinhoNum');
  const plural = document.getElementById('carrinhoPlural');
  const pluralS = document.getElementById('carrinhoPluralS');
  const lista = document.getElementById('carrinhoLista');

  num.textContent = carrinho.length;
  plural.textContent = carrinho.length === 1 ? '' : 's';
  pluralS.textContent = carrinho.length === 1 ? '' : 's';
  lista.textContent = carrinho.map(c => c.tema + ' · ' + c.subtipo).join('   —   ');

  if (carrinho.length > 0) {
    bar.classList.add('visivel');
  } else {
    bar.classList.remove('visivel');
  }
}

function limparCarrinho() {
  carrinho = [];
  document.querySelectorAll('.btn-add.adicionado').forEach(btn => {
    btn.classList.remove('adicionado');
    btn.textContent = 'Quero esta carta';
  });
  atualizarCarrinho();
}

function enviarWhatsApp() {
  if (carrinho.length === 0) return;

  const linhas = carrinho.map(c => '— ' + c.tema + ' · ' + c.subtipo).join('
');
  const total = carrinho.length;
  let plano = total === 1
    ? 'carta avulsa (R$ 3,90)'
    : total <= 3
    ? 'kit 3 cartas (R$ 7,00)'
    : 'baralho 10 cartas (R$ 25,00)';

  const msg = encodeURIComponent(
    'Oi! Quero desbloquear estas cartas do Te Vi 🤍

' +
    linhas +
    '

Acho que o ' + plano + ' faz sentido pra mim. Como faço?'
  );

  window.open('https://wa.me/' + SEU_NUMERO + '?text=' + msg, '_blank');
}
</script>

