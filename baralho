<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Te Vi — Baralho</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --azul: #2C5F7A;
    --azul-claro: #7FB3C8;
    --areia: #f4ede4;
    --areia-escura: #e8ddd3;
    --terra: #C4A882;
    --texto: #111111;
    --texto-suave: #5a4d42;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { background: var(--areia); color: var(--texto); font-family: 'Jost', sans-serif; font-weight: 300; }

  header {
    background: linear-gradient(160deg, #1a2e3b 0%, #2c5f7a 100%);
    padding: 48px 24px 56px;
    text-align: center;
  }
  header a { text-decoration: none; }
  .header-titulo { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 8vw, 72px); font-weight: 300; color: var(--areia); letter-spacing: 0.04em; line-height: 1; }
  .header-titulo span { color: var(--azul-claro); font-style: italic; }
  .header-tagline { font-family: 'Cormorant Garamond', serif; font-size: clamp(14px, 2.5vw, 19px); font-style: italic; color: rgba(244,237,228,0.65); margin-top: 14px; letter-spacing: 0.03em; }
  .header-divisor { width: 40px; height: 1px; background: var(--terra); margin: 24px auto; opacity: 0.7; }
  .header-volta { font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 300; color: rgba(244,237,228,0.4); letter-spacing: 0.2em; text-transform: uppercase; text-decoration: none; display: inline-block; margin-top: 4px; transition: color 0.3s; }
  .header-volta:hover { color: var(--terra); }

  .temas { max-width: 860px; margin: 0 auto; padding: 48px 24px 80px; }
  .tema { margin-bottom: 56px; }
  .tema-header { display: flex; align-items: center; gap: 16px; padding: 24px 0 16px; border-bottom: 1px solid rgba(196,168,130,0.25); margin-bottom: 24px; }
  .tema-icone { font-size: 28px; line-height: 1; }
  .tema-info { flex: 1; }
  .tema-nome { font-family: 'Cormorant Garamond', serif; font-size: clamp(22px, 4vw, 32px); font-weight: 300; color: var(--azul); line-height: 1.2; }
  .tema-subtitulo { font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terra); margin-top: 4px; }

  .cartas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }

  /* CARTA COM LINK — gratuita */
  a.carta-item {
    background: #faf7f3;
    border: 1px solid rgba(196,168,130,0.2);
    border-radius: 8px;
    padding: 24px 20px;
    display: flex; flex-direction: column; gap: 12px;
    transition: all 0.3s ease;
    text-decoration: none;
    position: relative;
  }
  a.carta-item:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(44,95,122,0.12); border-color: rgba(196,168,130,0.5); }

  /* CARTA PAGA — com cadeado */
  div.carta-item {
    background: #faf7f3;
    border: 1px solid rgba(196,168,130,0.2);
    border-radius: 8px;
    padding: 24px 20px;
    display: flex; flex-direction: column; gap: 12px;
    position: relative;
    overflow: hidden;
  }

  /* Overlay desfocado nas cartas pagas */
  div.carta-item::after {
    content: '';
    position: absolute;
    inset: 0;
    
    
    border-radius: 8px;
    pointer-events: none;
  }

  /* Cadeado dourado */
  div.carta-item .cadeado {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 28px;
    height: 28px;
    background: var(--terra);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(196,168,130,0.4);
  }

  div.carta-item .cadeado svg {
    width: 14px;
    height: 14px;
    fill: white;
  }

  .carta-subtipo { font-family: 'Jost', sans-serif; font-size: 10px; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terra); }
  .carta-preview { font-family: 'Cormorant Garamond', serif; font-size: 15px; font-style: italic; color: var(--texto); line-height: 1.6; flex: 1; }
  .carta-btn { font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: var(--azul); display: flex; align-items: center; gap: 6px; margin-top: 4px; transition: gap 0.3s ease; }
  a.carta-item:hover .carta-btn { gap: 10px; }
  .carta-btn::after { content: '→'; font-size: 13px; }

  footer { background: #1a2e3b; color: rgba(244,237,228,0.35); text-align: center; padding: 48px 24px; font-size: 12px; letter-spacing: 0.1em; }
  footer .nome { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 300; color: var(--areia); display: block; margin-bottom: 10px; }
  footer a { color: var(--azul-claro); text-decoration: none; }
  footer .cvv { margin-top: 16px; font-size: 11px; color: rgba(244,237,228,0.2); }

  @media (max-width: 480px) { .cartas-grid { grid-template-columns: 1fr; } }

  /* BOTÃO POR TEMA */
  .tema-desbloquear {
    margin-top: 16px;
    text-align: right;
  }
  .btn-desbloquear {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terra);
    text-decoration: none;
    border: 1px solid rgba(196,168,130,0.35);
    padding: 8px 16px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.25s ease;
  }
  .btn-desbloquear:hover {
    background: var(--terra);
    color: white;
    border-color: var(--terra);
  }
  .btn-desbloquear::after { content: '↓'; font-size: 12px; }

  /* BLOCO DE VENDA */
  .venda-ancora { display: block; position: relative; top: -80px; visibility: hidden; }
  .venda-bloco {
    background: linear-gradient(135deg, #1a2e3b 0%, #2c5f7a 100%);
    border-radius: 12px;
    padding: 48px 40px;
    margin: 48px 0 64px;
    color: var(--areia);
    position: relative;
    overflow: hidden;
  }
  .venda-bloco::before {
    content: '🔓';
    position: absolute;
    font-size: 120px;
    opacity: 0.05;
    right: 32px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
  .venda-subtitulo-bloco {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--azul-claro);
    margin-bottom: 8px;
  }
  .venda-titulo-bloco {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(22px, 4vw, 34px);
    font-weight: 300;
    font-style: italic;
    color: var(--areia);
    margin-bottom: 8px;
    line-height: 1.2;
  }
  .venda-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-style: italic;
    color: rgba(244,237,228,0.5);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .planos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }
  .plano {
    background: rgba(244,237,228,0.07);
    border: 1px solid rgba(244,237,228,0.12);
    border-radius: 8px;
    padding: 20px 16px;
    text-align: center;
    transition: all 0.3s ease;
  }
  .plano:hover { background: rgba(244,237,228,0.12); border-color: rgba(196,168,130,0.4); }
  .plano-nome {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--azul-claro);
    margin-bottom: 6px;
  }
  .plano-detalhe {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-style: italic;
    color: rgba(244,237,228,0.45);
    margin-bottom: 12px;
  }
  .plano-preco {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    font-weight: 400;
    color: var(--areia);
    line-height: 1;
  }
  .plano-preco span { font-size: 14px; color: rgba(244,237,228,0.45); font-weight: 300; }
  .plano.destaque { background: rgba(196,168,130,0.15); border-color: rgba(196,168,130,0.4); }
  .plano.destaque .plano-preco { color: var(--terra); }
  .venda-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--terra);
    color: white;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  .venda-cta:hover { background: #b89468; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(196,168,130,0.3); }
  .venda-cta::after { content: '→'; font-size: 14px; }
  .venda-nota {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    color: rgba(244,237,228,0.3);
    margin-top: 16px;
    letter-spacing: 0.05em;
  }

  /* MENU DE NAVEGAÇÃO */
  .nav-bar {
    background: #faf7f3;
    border-bottom: 1px solid rgba(196,168,130,0.25);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(44,95,122,0.06);
  }
  .nav-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-inner::-webkit-scrollbar { display: none; }
  .nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--texto-suave);
    text-decoration: none;
    padding: 16px 18px;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .nav-link:hover { color: var(--azul); border-bottom-color: var(--terra); }
  .nav-link.destaque {
    color: var(--azul);
    font-weight: 400;
    border-bottom-color: var(--azul);
  }
  .nav-link.destaque:hover { border-bottom-color: var(--terra); }
  .nav-separador {
    width: 1px;
    background: rgba(196,168,130,0.3);
    margin: 12px 4px;
    align-self: stretch;
  }

  /* CARRINHO FLUTUANTE */
  .carrinho-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #1a2e3b;
    border-top: 1px solid rgba(196,168,130,0.25);
    z-index: 999;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 -8px 40px rgba(0,0,0,0.25);
  }
  .carrinho-bar.visivel { transform: translateY(0); }
  .carrinho-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .carrinho-info {
    flex: 1;
    min-width: 160px;
  }
  .carrinho-contagem {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-style: italic;
    color: var(--areia);
    line-height: 1.2;
  }
  .carrinho-contagem strong {
    color: var(--terra);
    font-style: normal;
  }
  .carrinho-lista {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(244,237,228,0.4);
    margin-top: 4px;
    max-height: 36px;
    overflow: hidden;
  }
  .carrinho-acoes {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .btn-limpar {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(244,237,228,0.3);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    transition: color 0.2s;
  }
  .btn-limpar:hover { color: rgba(244,237,228,0.7); }
  .btn-enviar-wpp {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--terra);
    color: white;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 12px 22px;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }
  .btn-enviar-wpp:hover { background: #b89468; transform: translateY(-1px); }

  /* BOTÃO ADICIONAR NA CARTA COM CADEADO */
  div.carta-item .btn-add {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--terra);
    background: none;
    border: 1px solid rgba(196,168,130,0.35);
    border-radius: 4px;
    padding: 7px 12px;
    cursor: pointer;
    width: 100%;
    margin-top: 4px;
    transition: all 0.25s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  div.carta-item .btn-add:hover {
    background: var(--terra);
    color: white;
    border-color: var(--terra);
  }
  div.carta-item .btn-add.adicionado {
    background: rgba(196,168,130,0.12);
    color: var(--azul);
    border-color: rgba(44,95,122,0.3);
  }
  div.carta-item .btn-add.adicionado::before { content: '✓ '; }

</style>
</head>
